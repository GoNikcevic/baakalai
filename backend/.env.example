# ============================================
# BAKAL Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- Server ---
PORT=3001
# NODE_ENV=production  # Uncomment in production (enforces JWT_SECRET + ENCRYPTION_SECRET)

# --- Database ---
# Option 1: Local SQLite (for development, no external dependency)
DATABASE_PATH=./data/bakal.db

# Option 2: Supabase PostgreSQL (for production)
# Uncomment below and comment out DATABASE_PATH above to use PostgreSQL
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Set to "false" to disable SSL (for local PostgreSQL)
# DATABASE_SSL=false

# --- Supabase API (frontend direct access) ---
# From Supabase: Settings → API → Project URL and anon/public key
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Defaults to localhost:3000,3001,5173 in dev.
# CORS_ORIGINS=https://app.bakal.fr,https://bakal.fr

# --- Authentication ---
# Secret for signing JWT tokens (REQUIRED in production).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# --- Encryption ---
# Secret used to encrypt API keys stored in the database (REQUIRED in production).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# --- Lemlist API ---
# Get your API key: Lemlist → Settings → Integrations → API
LEMLIST_API_KEY=your_lemlist_api_key_here

# --- Notion API ---
# 1. Go to https://www.notion.so/my-integrations
# 2. Create a new integration (name: "Bakal Backend")
# 3. Copy the "Internal Integration Secret"
# 4. Share each database with this integration (... menu → Connections → Add)
NOTION_TOKEN=your_notion_integration_token_here

# Notion database IDs (filled automatically by: npm run setup-notion)
# Or copy them manually from each database URL:
#   https://notion.so/workspace/<DATABASE_ID>?v=...
NOTION_DB_RESULTATS=
NOTION_DB_DIAGNOSTICS=
NOTION_DB_HISTORIQUE=
NOTION_DB_MEMOIRE=

# Parent page ID for database creation (required for setup-notion script)
# This is the Notion page under which the 4 databases will be created
NOTION_PARENT_PAGE_ID=

# --- Orchestrator (cron jobs) ---
# Set to "true" to enable automatic stats collection (daily 8am)
# and memory consolidation (monthly 1st 9am).
# Leave disabled until Lemlist + Claude API keys are configured.
ORCHESTRATOR_ENABLED=false

# --- Claude API (Anthropic) ---
# Get your API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- pgvector + Voyage AI (semantic memory search) ---
# Set PGVECTOR_ENABLED to "true" to enable vector-based semantic search.
# Requires the vector extension on Supabase (migration 025 + 026).
# PGVECTOR_ENABLED=false
# Voyage AI embedding API key (https://www.voyageai.com)
# Model: voyage-3, 1024 dimensions, $0.06/1M tokens
VOYAGE_API_KEY=

# --- Brave Search API (web prospect agent) ---
# Sign up at https://api.search.brave.com — free tier = 2000 queries/month
BRAVE_SEARCH_API_KEY=

# --- Google OAuth (signup/login via Google) ---
# Create credentials: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend — verification + password reset) ---
# Create account + API key: https://resend.com
# Verify your sending domain in Resend dashboard first
RESEND_API_KEY=
FROM_EMAIL=Baakalai <noreply@support.baakal.ai>

# --- App URL (used for email links, OAuth redirects) ---
# In production, set this to your actual frontend URL
# If RAILWAY_PUBLIC_DOMAIN is set, it auto-derives from that
APP_URL=http://localhost:5173

# --- File Storage (S3-compatible — Supabase Storage or AWS S3) ---
S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
S3_BUCKET=documents
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Database pool tuning (optional) ---
# DB_POOL_MAX=20
# DB_POOL_MIN=2

# --- Logging ---
# LOG_LEVEL=info  # debug, info, warn, error

# --- HubSpot CRM ---
# HubSpot tokens are now stored PER-USER in the database (user_integrations table).
# Each client configures their own HubSpot token in Settings → CRM → HubSpot.
# No global HUBSPOT_ACCESS_TOKEN env var is needed anymore.
