# N8N Configuration
N8N_PORT=5678
N8N_ENCRYPTION_KEY=generate-a-random-key-here
N8N_USER=admin
N8N_PASSWORD=change-me

# Webhook URL (set to your Railway public URL in production)
WEBHOOK_URL=http://localhost:5678/

# Bakal API Keys
LEMLIST_API_KEY=your-lemlist-api-key
NOTION_TOKEN=your-notion-integration-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Postgres (for production instead of SQLite)
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=your-db-host
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=your-db-password
